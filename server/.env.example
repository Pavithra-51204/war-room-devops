# ── MongoDB Atlas ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/warroom?retryWrites=true&w=majority

# ── Redis (Upstash / ElastiCache / self-hosted) ────────────────
REDIS_URL=redis://localhost:6379
# For TLS (Upstash etc.):  rediss://<user>:<password>@host:port

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=supersecretkey_replace_in_prod
JWT_EXPIRES_IN=8h

# ── Server ─────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
